# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_PASSWORD=
# Claude API — used for page classification and field extraction
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-opus-4-8)
# AI_MODEL=claude-opus-4-8
# Optional cheaper model and limits for inbound email routing before full parsing
# LIGHT_AI_MODEL=claude-opus-4-8
LIGHT_ROUTING_MAX_ATTACHMENTS=5
LIGHT_ROUTING_MAX_PDF_PAGES=3
LIGHT_ROUTING_MAX_FILE_MB=12

# Secret for inbound email webhooks (/api/inbound-email)
INBOUND_EMAIL_WEBHOOK_SECRET=change-me
# Max full Postmark JSON webhook body accepted by the Next app.
# Attachments are base64 encoded, so a 7 MB PDF is roughly a 9.4 MB JSON body.
INBOUND_EMAIL_MAX_WEBHOOK_BYTES=10000000
# Optional separate secret for scheduled email routing jobs (/api/jobs/email-routing)
# Defaults to CRON_SECRET when unset.
EMAIL_ROUTING_JOB_SECRET=change-me

# Upload limits / retention
NEXT_PUBLIC_MAX_FILE_MB=50
NEXT_PUBLIC_PDF_RETENTION_DAYS=14

# Secret for the retention cleanup endpoint (/api/cron/cleanup)
CRON_SECRET=change-me
